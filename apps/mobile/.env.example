# Copy to .env and set the API URL the app talks to.
# - Android emulator:   http://10.0.2.2:3000  (maps to your machine's localhost)
# - Physical device:    http://<your-machine-LAN-IP>:3000
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Google OAuth Web client ID (from Google Cloud) to enable Google Sign-In.
# Must match the GOOGLE_CLIENT_ID configured on the API. See docs/auth.md.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
