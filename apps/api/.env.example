# Process API environment
NODE_ENV=development
PORT=3000

# Postgres. Local dev: `docker compose up -d` uses this:
DATABASE_URL=postgres://process:process@localhost:5432/process

# Auth (Better Auth). Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Google Cloud OAuth (see docs/auth.md). Sign-in stays disabled until these are set:
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meals AI. FatSecret needs your server's IP whitelisted in its console.
ANTHROPIC_API_KEY=
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
